# Oh My Coder - 环境变量配置示例
# 复制此文件为 .env 并填入真实的 API Key
# cp examples/.env.example .env

# ============================================
# 必填（至少一个）
# ============================================

# DeepSeek（推荐，性价比高）
DEEPSEEK_API_KEY=<your_deepseek_api_key>

# ============================================
# 可选 - 国内模型
# ============================================

# 智谱 GLM（GLM-4.7-Flash 永久免费）
GLM_API_KEY=<your_glm_api_key>

# 通义千问
TONGYI_API_KEY=<your_tongyi_api_key>

# Kimi 月暗
KIMI_API_KEY=<your_kimi_api_key>

# 字节豆包
DOUBAO_API_KEY=<your_doubao_api_key>

# MiniMax 海螺
MINIMAX_API_KEY=<your_minimax_api_key>

# 天工AI
TIANGONG_API_KEY=<your_tiangong_api_key>

# 百川智能
BAICHUAN_API_KEY=<your_baichuan_api_key>

# 文心一言（需要两个 Key）
WENXIN_API_KEY=<your_wenxin_api_key>
WENXIN_SECRET_KEY=<your_wenxin_secret_key>

# 腾讯混元（需要两个 Key）
HUNYUAN_API_KEY=<your_hunyuan_api_key>
HUNYUAN_SECRET_KEY=<your_hunyuan_secret_key>

# 讯飞星火（需要三个凭证）
SPARK_API_KEY=<your_spark_api_key>
SPARK_APP_ID=<your_spark_app_id>
SPARK_SECRET_KEY=<your_spark_secret_key>

# ============================================
# 可选 - 高级配置
# ============================================

# DeepSeek API 地址（使用代理时填写）
# DEEPSEEK_API_BASE=https://your-proxy.com/v1

# 请求超时（秒）
# REQUEST_TIMEOUT=60

# 日志级别
# LOG_LEVEL=INFO
